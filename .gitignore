# WordPress Plugin - KW Security
# Ignore common development and system files

# IDE files
.idea/
.vscode/
*.sublime-*

# System files
.DS_Store
Thumbs.db
desktop.ini

# Log files
*.log
error_log

# Temporary files
*.tmp
*.temp
*~

# Backup files
*.bak
*.backup

# Compressed files
*.zip
*.tar.gz
*.rar

# Development files
node_modules/
.sass-cache/
*.map

# WordPress specific
wp-config-local.php
.htaccess.local

